data/
excels test/
excels tests 2/
anciennes et autres versions/
pour bosser les plannifs/
points/
templates/
*.docx
_*.py

# Environnements virtuels
.venv/
venv/
env/

# Frontend : node_modules locaux uniquement (src compile au deploy Docker)
frontend/node_modules/

# Streamlit (non utilisé en production Docker)
app/
.streamlit/

# Scripts locaux
scripts/
